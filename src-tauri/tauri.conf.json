{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lyric Overlay",
  "version": "0.10.0",
  "identifier": "com.syvr.lyric-overlay",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lyric Overlay — Dev console",
        "width": 720,
        "height": 480,
        "center": true,
        "resizable": true,
        "decorations": true,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "overlay",
        "title": "Lyric Overlay",
        "width": 1100,
        "height": 200,
        "x": 200,
        "y": 60,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "settings",
        "title": "Lyric Overlay — Settings",
        "width": 560,
        "height": 680,
        "minWidth": 480,
        "minHeight": 560,
        "resizable": true,
        "decorations": true,
        "center": true,
        "visible": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data:; connect-src 'self' https:; media-src 'self' asset:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/syvrstudios/lyric-overlay/releases/latest/download/latest.json"
      ],
      "pubkey": "",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
